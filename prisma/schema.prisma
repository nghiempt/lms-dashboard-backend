// ============================================================
//  LMS DASHBOARD — PRISMA SCHEMA (ERD)
//  PostgreSQL. Bao phủ 17 nhóm chức năng theo tài liệu BA.
//  Hai role: ADMIN (kèm RBAC) và STUDENT (học viên).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== ENUMS ===================

enum UserRole {
  ADMIN
  STUDENT
}

enum UserStatus {
  ACTIVE // hoạt động
  LOCKED // bị khoá
  PENDING // chờ xác thực email
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum CoursePricing {
  FREE
  PAID
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ
}

enum VideoSource {
  BUNNY
  YOUTUBE
}

enum LessonLevel {
  BASIC // Cơ bản
  ADVANCED // Nâng cao
}

enum EnrollmentStatus {
  LEARNING // đang học
  COMPLETED // đã hoàn thành
  EXPIRED // hết hạn
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OrderStatus {
  PENDING // chờ thanh toán
  PAID // đã thanh toán
  CANCELLED // đã huỷ
  REFUNDED // hoàn tiền
  EXPIRED // quá hạn thanh toán
}

enum PaymentMethod {
  SEPAY // cổng SePay
  BANK_TRANSFER // chuyển khoản ngân hàng thủ công
  FREE // khoá miễn phí (ghi nhận 0đ)
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum DocumentKind {
  GOOGLE_DRIVE
  GOOGLE_DOCS
  PDF
  ARTICLE
  LINK
  FILE
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum NotificationType {
  SYSTEM
  COURSE
  PAYMENT
  PROMOTION
  COMMUNITY
}

enum NotificationScope {
  ALL // gửi tất cả học viên
  USER // gửi học viên cụ thể
  COURSE // gửi học viên đã đăng ký 1 khoá
}

enum NotificationStatus {
  DRAFT // nháp, chưa gửi
  SENT // đã gửi tới người nhận
}

// =================== AUTH & USERS ===================

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String?      // null nếu đăng nhập Google-only
  fullName        String
  phone           String?
  avatarUrl       String?
  bio             String?
  role            UserRole     @default(STUDENT)
  status          UserStatus   @default(PENDING)
  provider        AuthProvider @default(LOCAL)
  googleId        String?      @unique
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // tuỳ chọn thông báo (settings tab)
  notifyEmail     Boolean @default(true)
  notifyStudyReminder Boolean @default(true)
  notifyCommunity Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  adminRoles        AdminRoleAssignment[]
  devices           Device[]
  refreshTokens     RefreshToken[]
  enrollments       Enrollment[]
  lessonProgress    LessonProgress[]
  lessonAccessGrants LessonAccessGrant[]
  orders            Order[]
  payments          Payment[]
  notifications     NotificationRecipient[]
  accessLogs        VideoAccessLog[]
  activityLogs      ActivityLog[]
  studySessions     StudySession[]
  posts             Post[]
  documentsCreated  Document[]      @relation("DocumentCreator")
  mediaUploaded     Media[]         @relation("MediaUploader")
  articlesAuthored  Article[]       @relation("ArticleAuthor")
  notificationsSent Notification[]  @relation("NotificationSender")

  @@index([role, status])
  @@map("users")
}

// RBAC cho admin: vai trò + quyền
model AdminRole {
  id          String                @id @default(uuid())
  name        String                @unique // VD: SUPER_ADMIN, CONTENT_MANAGER
  description String?
  permissions AdminRolePermission[]
  assignments AdminRoleAssignment[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@map("admin_roles")
}

model Permission {
  id          String                @id @default(uuid())
  key         String                @unique // VD: course.create, user.lock
  description String?
  roles       AdminRolePermission[]
  createdAt   DateTime              @default(now())

  @@map("permissions")
}

model AdminRolePermission {
  roleId       String
  permissionId String
  role         AdminRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("admin_role_permissions")
}

model AdminRoleAssignment {
  userId    String
  roleId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([userId, roleId])
  @@map("admin_role_assignments")
}

// =================== DEVICES & SESSIONS ===================

model Device {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String   // fingerprint do FE sinh ra
  deviceName   String?  // VD: "Chrome on macOS"
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  refreshTokens RefreshToken[]

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("devices")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String?
  device    Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// Token 1 lần: xác thực email / reset mật khẩu
model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  tokenHash String   @unique
  type      String   // EMAIL_VERIFY | PASSWORD_RESET
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("verification_tokens")
}

// =================== COURSES ===================

model Course {
  id            String        @id @default(uuid())
  slug          String        @unique
  title         String
  shortCode     String?       // VD: "KP", "PE" (hiển thị thumbnail)
  subtitle      String?
  description   String?
  thumbnailUrl  String?
  coverLabel    String?       // text overlay trên cover (FE)
  pricing       CoursePricing @default(PAID)
  price         Decimal       @default(0) @db.Decimal(12, 2)
  originalPrice Decimal?      @db.Decimal(12, 2)
  status        CourseStatus  @default(DRAFT)
  // số ngày truy cập sau khi mua (null = trọn đời)
  accessDurationDays Int?
  isFeatured    Boolean       @default(false)
  order         Int           @default(0)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  chapters    Chapter[]
  enrollments Enrollment[]
  orderItems  OrderItem[]
  documents   Document[]

  @@index([status, pricing])
  @@map("courses")
}

model Chapter {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  description String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons  Lesson[]
  sections Section[]

  @@index([courseId])
  @@map("chapters")
}

// Nhóm bài (cấp trung gian Chương → Nhóm bài → Bài). Tùy chọn:
// lesson.sectionId = null nghĩa là bài nằm trực tiếp dưới chương.
model Section {
  id        String   @id @default(uuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons Lesson[]

  @@index([chapterId])
  @@map("sections")
}

model Lesson {
  id          String     @id @default(uuid())
  chapterId   String
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  // nhóm bài (tùy chọn): null = nằm trực tiếp dưới chương
  sectionId   String?
  section     Section?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  title       String
  description String?
  type        LessonType @default(VIDEO)
  // nguồn video: Bunny (bunnyVideoId) hoặc YouTube (videoUrl)
  videoSource VideoSource @default(BUNNY)
  bunnyVideoId String?
  videoUrl     String?    // YouTube id/url khi videoSource=YOUTUBE
  durationSec  Int?      // thời lượng video (giây)
  articleHtml  String?   // nội dung bài viết nếu type=ARTICLE
  level        LessonLevel @default(BASIC) // Cơ bản / Nâng cao
  // bài học preview/miễn phí: cho xem dù chưa mua
  isPreview   Boolean    @default(false)
  // khoá mặc định (admin có thể mở riêng cho từng học viên)
  isLocked    Boolean    @default(false)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  progress     LessonProgress[]
  accessGrants LessonAccessGrant[]
  videoLogs    VideoAccessLog[]
  attachments  LessonAttachment[]

  @@index([chapterId])
  @@index([sectionId])
  @@map("lessons")
}

// File đính kèm bài học (tài liệu PDF, source...)
model LessonAttachment {
  id        String  @id @default(uuid())
  lessonId  String
  lesson    Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  mediaId   String?
  media     Media?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  title     String
  url       String?
  createdAt DateTime @default(now())

  @@index([lessonId])
  @@map("lesson_attachments")
}

// Mở/khoá bài học cho từng học viên cụ thể (override isLocked)
model LessonAccessGrant {
  id        String   @id @default(uuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlocked  Boolean  @default(true) // true=mở khoá riêng, false=khoá riêng
  createdAt DateTime @default(now())

  @@unique([lessonId, userId])
  @@map("lesson_access_grants")
}

// =================== ENROLLMENT & PROGRESS ===================

model Enrollment {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(LEARNING)
  progressPct Int              @default(0) // 0..100 (cache)
  orderId     String?
  order       Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  enrolledAt  DateTime         @default(now())
  expiresAt   DateTime?        // null = trọn đời
  completedAt DateTime?
  lastAccessedAt DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@map("enrollments")
}

model LessonProgress {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId      String
  lesson        Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status        ProgressStatus @default(NOT_STARTED)
  watchedSec    Int            @default(0) // số giây đã xem
  lastPositionSec Int          @default(0) // vị trí dừng gần nhất
  completedAt   DateTime?
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

// Phiên học để tính "giờ học theo ngày" (biểu đồ FE)
model StudySession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String?
  durationSec  Int      @default(0)
  startedAt    DateTime @default(now())
  endedAt      DateTime?

  @@index([userId, startedAt])
  @@map("study_sessions")
}

// =================== ORDERS & PAYMENTS ===================

model Order {
  id          String      @id @default(uuid())
  code        String      @unique // VD: INV-2042
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      OrderStatus @default(PENDING)
  subtotal    Decimal     @db.Decimal(12, 2)
  discount    Decimal     @default(0) @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  currency    String      @default("VND")
  note        String?
  paidAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
  payments    Payment[]
  enrollments Enrollment[]

  @@index([userId, status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Restrict)
  title     String  // snapshot tên khoá
  price     Decimal @db.Decimal(12, 2)
  quantity  Int     @default(1)

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("VND")
  // SePay / bank transfer
  transactionId String?       // id giao dịch từ SePay
  referenceCode String?       // nội dung CK / mã đối soát
  bankAccount   String?
  bankName      String?
  rawPayload    Json?         // lưu payload webhook gốc để đối soát
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([transactionId])
  @@map("payments")
}

// =================== MEDIA (MinIO) & DOCUMENTS ===================

model Media {
  id           String    @id @default(uuid())
  uploaderId   String?
  uploader     User?     @relation("MediaUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  type         MediaType @default(OTHER)
  fileName     String
  objectKey    String    @unique // key trong bucket MinIO
  url          String    // url public/proxy
  mimeType     String?
  sizeBytes    Int?
  width        Int?
  height       Int?
  folder       String?   // phân nhóm: avatars, courses, posts...
  createdAt    DateTime  @default(now())

  lessonAttachments LessonAttachment[]
  documents         Document[]

  @@index([type, folder])
  @@map("media")
}

// Kho tài liệu tặng học viên
model Document {
  id          String       @id @default(uuid())
  title       String
  description String?
  kind        DocumentKind @default(LINK)
  url         String?      // link Google Drive/Docs/PDF...
  mediaId     String?      // hoặc file trên MinIO
  media       Media?       @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  contentHtml String?      // nếu là bài viết
  category    String?
  fileType    String?      // nhãn loại file hiển thị: "PDF", "LUT · .cube"...
  sizeBytes   Int?
  downloadCount Int        @default(0)
  courseId    String?      // tài liệu thuộc khoá nào (null = tất cả khoá)
  course      Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  isPublic    Boolean      @default(true) // true = mọi học viên xem được
  order       Int          @default(0)
  createdById String?
  createdBy   User?        @relation("DocumentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category, isPublic])
  @@index([courseId])
  @@map("documents")
}

// =================== CONTENT / CMS ===================

// Bài viết (blog/landing)
model Article {
  id          String     @id @default(uuid())
  slug        String     @unique
  title       String
  excerpt     String?
  contentHtml String?
  coverUrl    String?
  status      PostStatus @default(DRAFT)
  authorId    String?
  author      User?      @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@map("articles")
}

// Khối nội dung Landing Page (key-value động)
model LandingSection {
  id        String   @id @default(uuid())
  key       String   @unique // VD: hero, features, pricing
  title     String?
  content   Json     // nội dung tuỳ biến theo block
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("landing_sections")
}

// ============================================================
//  LANDING PAGE — KHOÁ HỌC HIỂN THỊ TRÊN LP MARKETING
//  Tách HOÀN TOÀN khỏi model Course (hệ thống học thật).
//  Chỉ phục vụ hiển thị + bán hàng trên Landing Page.
// ============================================================

model LandingCourse {
  id       String @id @default(uuid())
  slug     String @unique // premium | premium-elite

  // ----- card giá (hiển thị trang chủ LP) -----
  title    String // "Khóa Premium"
  price    String // giữ nguyên văn định dạng: "5.890.000"
  currency String  @default("VNĐ")
  featured Boolean @default(false) // card nổi bật
  badge    String? // "Giới hạn mỗi tháng"
  features Json    @default("[]") // string[] — danh sách bullet trên card

  // ----- header trang chi tiết -----
  tag          String? // mô tả ngắn dưới tiêu đề
  accessLabel  String  @default("trọn đời") // "Truy cập trọn đời"
  supportLabel String  @default("1:1") // "Hỗ trợ 1:1"
  ctaUrl       String? // link nút "Tham gia khóa học"

  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapters LandingCourseChapter[]

  @@map("course_landing_page")
}

model LandingCourseChapter {
  id          String        @id @default(uuid())
  courseId    String
  course      LandingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  label       String // nhãn cover: "Foundation"
  name        String // "Nhập môn & Tư duy nghề"
  description String? // mô tả chương
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lessons LandingCourseLesson[]

  @@index([courseId])
  @@map("course_landing_page_chapters")
}

model LandingCourseLesson {
  id        String               @id @default(uuid())
  chapterId String
  chapter   LandingCourseChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title     String // "Chào mừng & lộ trình khóa học"
  videoUrl  String? // url video (admin điền)
  duration  String? // hiển thị: "04:30"
  order     Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([chapterId])
  @@map("course_landing_page_lessons")
}

// Menu website
model Menu {
  id        String   @id @default(uuid())
  label     String
  url       String
  parentId  String?
  parent    Menu?    @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Menu[]   @relation("MenuTree")
  location  String   @default("header") // header | footer
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([location])
  @@map("menus")
}

// =================== COMMUNITY ===================

model CommunityGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String?  // VD: Việc làm, Quốc tế
  memberCount Int      @default(0)
  joinUrl     String?
  iconUrl     String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("community_groups")
}

model Post {
  id        String     @id @default(uuid())
  title     String
  contentHtml String?
  authorId  String?
  author    User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String?   // snapshot/hiển thị
  category  String?
  likeCount Int        @default(0)
  status    PostStatus @default(PUBLISHED)
  isFeatured Boolean   @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, isFeatured])
  @@map("posts")
}

// =================== NOTIFICATIONS ===================

model Notification {
  id        String            @id @default(uuid())
  title     String
  body      String
  type      NotificationType  @default(SYSTEM)
  scope     NotificationScope @default(ALL)
  status    NotificationStatus @default(SENT)
  courseId  String?           // khi scope=COURSE
  link      String?
  senderId  String?
  sender    User?             @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  sentAt    DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  recipients NotificationRecipient[]

  @@index([type, scope])
  @@index([status])
  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId, isRead])
  @@map("notification_recipients")
}

// =================== VIDEO ACCESS LOG (Nhật ký truy cập) ===================

model VideoAccessLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId   String?
  lesson     Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  bunnyVideoId String?
  deviceId   String?
  ipAddress  String?
  userAgent  String?
  watermark  String?  // text watermark đã cấp (email/tên)
  accessedAt DateTime @default(now())

  @@index([userId, accessedAt])
  @@index([lessonId])
  @@map("video_access_logs")
}

// =================== ACTIVITY LOG (Nhật ký hoạt động) ===================

enum ActivityType {
  LOGIN
  LOGOUT
  REGISTER
  VIEW_LESSON
  COMPLETE_CHAPTER
  PURCHASE
  DOWNLOAD
  OTHER
}

// Nhật ký hoạt động tổng quát của học viên (login, mua, xem bài, tải tài liệu...)
model ActivityLog {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActivityType @default(OTHER)
  action      String       // mô tả hành động (hiển thị FE)
  ipAddress   String?
  userAgent   String?
  deviceLabel String?      // VD: "Chrome · macOS"
  meta        Json?
  createdAt   DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@map("activity_logs")
}

// =================== SYSTEM SETTINGS ===================

// Cấu hình hệ thống dạng key-value (group để admin nhóm UI)
model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique // VD: site.name, payment.bank_account, social.facebook
  value     String?
  group     String   @default("general") // general | payment | email | social | contact
  type      String   @default("string")  // string | number | boolean | json
  label     String?
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_settings")
}
